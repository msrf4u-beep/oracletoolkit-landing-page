{
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.oracletoolkit.com"
        }
      ],
      "destination": "https://oracletoolkit.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{"key": "Content-Type", "value": "application/xml; charset=utf-8"}]
    },
    {
      "source": "/robots.txt",
      "headers": [{"key": "Content-Type", "value": "text/plain; charset=utf-8"}]
    }
  ]
}
